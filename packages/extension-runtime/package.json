{
  "name": "@libztbs/extension-runtime",
  "version": "0.2.0",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/plenoai/pleno-audit.git",
    "directory": "packages/extension-runtime"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    },
    "./storage-types": {
      "types": "./dist/storage-types.d.ts",
      "import": "./dist/storage-types.js"
    },
    "./cooldown": {
      "types": "./dist/cooldown-manager.d.ts",
      "import": "./dist/cooldown-manager.js"
    },
    "./browser": {
      "types": "./dist/browser-adapter.d.ts",
      "import": "./dist/browser-adapter.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@libztbs/ai-detector": "workspace:*",
    "@libztbs/alerts": "workspace:*",
    "@libztbs/types": "workspace:*",
    "@libztbs/csp": "workspace:*",
    "@libztbs/detectors": "workspace:*",
    "@libztbs/nrd": "workspace:*"
  }
}
