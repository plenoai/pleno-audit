{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/api/schema/stryker-core.schema.json",
  "plugins": [
    "@stryker-mutator/vitest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "mutate": [
    "packages/core/src/nrd/**/*.ts",
    "!packages/core/src/nrd/**/*.test.ts",
    "!packages/core/src/nrd/**/*.property.ts",
    "!packages/core/src/nrd/index.ts",
    "packages/core/src/typosquat/**/*.ts",
    "!packages/core/src/typosquat/**/*.test.ts",
    "!packages/core/src/typosquat/**/*.property.ts",
    "!packages/core/src/typosquat/index.ts",
    "!packages/core/src/typosquat/types.ts"
  ],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.packages.json",
  "reporters": ["clear-text", "html"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "ignorePatterns": [".claude"],
  "concurrency": 4,
  "timeoutMS": 30000
}
