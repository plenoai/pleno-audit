{
  "name": "pleno-audit",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @pleno-audit/debugger start dev start",
    "dev:stop": "pnpm --filter @pleno-audit/debugger start dev stop",
    "dev:ext": "pnpm -C app/audit-extension dev",
    "clean": "rm -rf app/*/dist packages/*/dist coverage/",
    "build": "pnpm clean && pnpm -r --filter './packages/*' --filter './app/*' build",
    "website": "pnpm -C app/website dev",
    "website:build": "pnpm -C app/website build",
    "battacker-web": "pnpm -C app/battacker-web dev",
    "battacker-web:build": "pnpm --filter @libztbs/battacker build && pnpm -C app/battacker-web build",
    "enterprise": "pnpm -C app/audit-enterprise dev",
    "enterprise:build": "pnpm -C app/audit-enterprise build",
    "typecheck": "tsc -p tsconfig.packages.json --noEmit",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:ui": "vitest run --config app/audit-extension/vitest.config.ts",
    "test:all": "pnpm test && pnpm test:ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.1.38",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.2",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.1",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  }
}
