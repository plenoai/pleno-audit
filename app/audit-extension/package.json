{
  "name": "@pleno-audit/audit-extension",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "prebuild:hooks": "pnpm --filter @libztbs/main-world-hooks run build:hooks",
    "dev": "pnpm prebuild:hooks && wxt",
    "dev:firefox": "pnpm prebuild:hooks && wxt -b firefox",
    "build": "pnpm prebuild:hooks && wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:all": "wxt build && wxt build -b firefox"
  },
  "dependencies": {
    "@libztbs/ai-detector": "workspace:*",
    "@libztbs/alerts": "workspace:*",
    "@libztbs/background-services": "workspace:*",
    "@libztbs/types": "workspace:*",
    "@libztbs/csp": "workspace:*",
    "@libztbs/data-export": "workspace:*",
    "@libztbs/debug-bridge": "workspace:*",
    "@libztbs/detectors": "workspace:*",

    "@libztbs/extension-network-service": "workspace:*",
    "@libztbs/extension-enterprise": "workspace:*",
    "@libztbs/extension-runtime": "workspace:*",
    "@libztbs/nrd": "workspace:*",
    "@libztbs/typosquat": "workspace:*",
    "lucide-preact": "^0.577.0",
    "preact": "^10.29.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "typescript": "^5.9.3",
    "wxt": "^0.20.20"
  }
}
