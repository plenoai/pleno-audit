    "@libztbs/types": "^0.2.0",
    "@libztbs/csp": "^0.2.0",
    "@libztbs/data-export": "^0.2.0",
    "@libztbs/debug-bridge": "^0.2.0",
    "@libztbs/detectors": "^0.2.0",
    "@libztbs/extension-network-service": "^0.2.0",
    "@libztbs/extension-enterprise": "^0.2.0",
    "@libztbs/extension-runtime": "^0.2.0",
    "@libztbs/nrd": "^0.2.0",
    "@libztbs/typosquat": "^0.2.0",
    "lucide-preact": "^0.577.0",
    "preact": "^10.29.0"
  },
